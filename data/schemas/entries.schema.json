{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/entries.schema.json",
  "title": "CIDR dataset",
  "type": "object",
  "required": ["version", "generated_hint", "entries"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_hint": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cidr",
          "label",
          "category",
          "source",
          "added_at",
          "last_verified_at",
          "confidence"
        ],
        "properties": {
          "cidr": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "category": {
            "type": "string",
            "enum": ["cdn", "cloud", "hosting", "messaging", "dns", "misc"]
          },
          "source": {
            "type": "object",
            "required": ["kind", "ref", "url"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "ref": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          },
          "added_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "last_verified_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "notes": { "type": "string" },
          "allow_multi_category": { "type": "boolean" },
          "wide_ok": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
